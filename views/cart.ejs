<%- include('./partials/header') %>

<div class="w-full min-h-screen px-20 py-10">

  <h1 class="text-3xl font-semibold mb-8">Your Cart</h1>

  <% if(items.length === 0) { %>
    <h2 class="text-xl text-gray-500">Your cart is empty</h2>
  <% } %>

  <% items.forEach(function(item) { %>
    <div class="w-full flex items-center justify-between border-b py-5">

      <div class="w-24 h-24 flex justify-center items-center bg-gray-100 rounded-md overflow-hidden">
        <img class="h-full" src="data:image/jpeg;base64, <%= item.image.toString('base64') %>" alt="">
      </div>

      <div class="w-1/4">
        <h3 class="text-lg font-medium"><%= item.name %></h3>
        <p class="text-gray-500">₹ <%= item.price %> each</p>
      </div>

      <div class="flex items-center gap-3">
        <a href="/cart/decrement/<%= item._id %>">
          <i class="w-8 h-8 bg-gray-200 flex rounded-full items-center justify-center ri-subtract-line cursor-pointer"></i>
        </a>
        <div class="px-3 py-1 rounded-md bg-gray-100"><%= item.quantity %></div>
        <a href="/cart/increment/<%= item._id %>">
          <i class="w-8 h-8 bg-gray-200 flex rounded-full items-center justify-center ri-add-line cursor-pointer"></i>
        </a>
      </div>

      <div class="w-1/6 text-right">
        <h3 class="text-lg font-semibold">₹ <%= item.itemTotal %></h3>
      </div>

    </div>
  <% }) %>

  <div class="w-full flex justify-end mt-10">
    <div class="w-1/3 flex justify-between items-center border-t pt-5">
      <h2 class="text-xl font-semibold">Total Amount</h2>
      <h2 class="text-xl font-bold text-green-600">₹ <%= grandTotal %></h2>
    </div>
  </div>

</div>

<%- include('./partials/footer') %>