<%- include('./partials/header') %>

<div class="w-full min-h-screen px-20 py-10">

  <h1 class="text-3xl font-semibold mb-8">My Account</h1>

  <div class="w-full max-w-xl bg-gray-100 rounded-md p-6">
    <div class="flex justify-between py-3 border-b">
      <h4 class="font-medium">Name</h4>
      <h4><%= user.fullname || user.name %></h4>
    </div>

    <div class="flex justify-between py-3 border-b">
      <h4 class="font-medium">Email</h4>
      <h4><%= user.email %></h4>
    </div>

    <div class="flex justify-between py-3 border-b">
      <h4 class="font-medium">Items in Cart</h4>
      <h4><%= user.cart.length %></h4>
    </div>
  </div>

</div>

<%- include('./partials/footer') %>